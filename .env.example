# Slack App のトークン
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# チャンネル設定（最大10チャンネル）
# SLACK_CHANNEL_N: チャンネルID（Slack の内部ID、例: C01XXXXXX）
# SLACK_CHANNEL_N_NAME: チャンネル名（ログ表示用、任意）
# SLACK_CHANNEL_N_WORKDIR: 作業ディレクトリ（任意、Claude に特定のプロジェクトを操作させたい場合）
#
# 対応する System Prompt ファイル: config/prompts/channel_N.txt

SLACK_CHANNEL_1=
SLACK_CHANNEL_1_NAME=general

# SLACK_CHANNEL_2=
# SLACK_CHANNEL_2_NAME=coding
# SLACK_CHANNEL_2_WORKDIR=/path/to/your/project
